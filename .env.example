# ============================================================
#  SEGUNDO CEREBRO — Variables de Entorno
#  Copia este archivo como .env y rellena cada valor
# ============================================================

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- PostgreSQL ---
# Formato: postgresql://usuario:password@host:puerto/nombre_db
DATABASE_URL=postgresql://postgres:password@localhost:5432/segundo_cerebro

# --- JWT (usa un string largo y aleatorio) ---
JWT_SECRET=cambia_este_secreto_por_uno_muy_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# --- WhatsApp Cloud API (Meta for Developers) ---
# Token de acceso permanente de tu App de Meta
WHATSAPP_TOKEN=EAAG...
# ID del número de teléfono de negocio en Meta
WHATSAPP_PHONE_NUMBER_ID=1234567890
# Versión de la Graph API de Meta
WHATSAPP_API_VERSION=v19.0
# Token personalizado para verificar el webhook (puedes elegir cualquier string)
WEBHOOK_VERIFY_TOKEN=mi_token_secreto_de_verificacion
# App Secret de Meta (para validar firma HMAC del webhook)
WHATSAPP_APP_SECRET=abc123...

# --- Google Gemini ---
# Obtén tu clave en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
# Modelo a usar: gemini-1.5-flash (rápido y económico) o gemini-1.5-pro
GEMINI_MODEL=gemini-1.5-flash

# --- Google OAuth2 (Calendar & Workspace) ---
# Crea credenciales en https://console.cloud.google.com/
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# URI de redirección (debe coincidir con la configurada en GCP Console)
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# --- Scheduler ---
# Hora del resumen diario en formato cron (default: 7:00 AM hora local)
DAILY_DIGEST_CRON=0 7 * * *
# Zona horaria para el cron job
TZ=America/Mexico_City
